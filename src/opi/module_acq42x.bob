<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>acq42x$(MUUT):$(SITE)</name>
  <width>550</width>
  <height>540</height>
  <widget type="group" version="3.0.0">
    <name>OPI HEADER</name>
    <x>10</x>
    <y>10</y>
    <width>500</width>
    <height>50</height>
    <style>3</style>
    <transparent>true</transparent>
    <widget type="label" version="2.0.0">
      <name>OPI TARGET</name>
      <text>$(UUT):$(SITE) - $(SITE_MODEL)</text>
      <y>30</y>
      <width>500</width>
      <font>
        <font name="Header 2" family="Liberation Sans" style="BOLD" size="18.0">
        </font>
      </font>
    </widget>
    <widget type="label" version="2.0.0">
      <name>OPI NAME</name>
      <text>ACQ42X</text>
      <width>500</width>
      <height>30</height>
      <font>
        <font name="Header 1" family="Liberation Sans" style="BOLD" size="22.0">
        </font>
      </font>
    </widget>
  </widget>
  <widget type="embedded" version="2.0.0">
    <name>COUNTER clk_count</name>
    <macros>
      <func>SIG:clk_count</func>
      <label>clk_count</label>
      <site>$(SITE)</site>
    </macros>
    <file>components/func_counter.bob</file>
    <x>10</x>
    <y>70</y>
    <width>530</width>
    <height>50</height>
    <resize>2</resize>
  </widget>
  <widget type="embedded" version="2.0.0">
    <name>COUNTER sample_count</name>
    <macros>
      <func>SIG:sample_count</func>
      <label>sample_count</label>
      <site>$(SITE)</site>
    </macros>
    <file>components/func_counter.bob</file>
    <x>10</x>
    <y>120</y>
    <width>530</width>
    <height>50</height>
    <resize>2</resize>
  </widget>
  <widget type="group" version="3.0.0">
    <name>SHOT</name>
    <x>10</x>
    <y>180</y>
    <width>90</width>
    <height>60</height>
    <style>3</style>
    <transparent>true</transparent>
    <widget type="label" version="2.0.0">
      <name>LABEL_9</name>
      <text>SHOT</text>
      <width>50</width>
      <height>30</height>
      <font>
        <font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0">
        </font>
      </font>
      <vertical_alignment>1</vertical_alignment>
    </widget>
    <widget type="textupdate" version="2.0.0">
      <name>UPDATE_9</name>
      <pv_name>${UUT}:${SITE}:SHOT</pv_name>
      <y>30</y>
      <width>90</width>
      <height>30</height>
      <precision>0</precision>
      <horizontal_alignment>1</horizontal_alignment>
      <vertical_alignment>1</vertical_alignment>
      <rules>
        <rule name="RUN_STATE" prop_id="background_color" out_exp="false">
          <exp bool_exp="pv0 == true &amp;&amp; pv1 &gt; 0">
            <value>
              <color name="On" red="0" green="255" blue="0">
              </color>
            </value>
          </exp>
          <exp bool_exp="pv0 == true &amp;&amp; pv1 == 0">
            <value>
              <color name="Attention" red="255" green="160" blue="0">
              </color>
            </value>
          </exp>
          <exp bool_exp="pv0 == false">
            <value>
              <color name="Read_Background" red="240" green="240" blue="240">
              </color>
            </value>
          </exp>
          <pv_name>${UUT}:${SITE}:RUN</pv_name>
          <pv_name>${UUT}:${SITE}:SIG:sample_count:COUNT</pv_name>
        </rule>
      </rules>
      <border_alarm_sensitive>$(SHOW_ALARM=1)</border_alarm_sensitive>
    </widget>
  </widget>
