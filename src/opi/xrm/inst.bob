<display version="2.0.0">
  <name>INST $(MUUT):$(CH)</name>
  <width>750</width>
  <height>740</height>
  <widget type="group" version="3.0.0">
    <name>SYSTEM</name>
    <x>10</x>
    <y>10</y>
    <width>690</width>
    <height>560</height>
    <style>3</style>
    <transparent>true</transparent>
    <widget type="label" version="2.0.0">
      <name>TITLE_1</name>
      <text>INST CH:$(CH) $(UUT)</text>
      <width>330</width>
      <height>50</height>
      <font>
        <font name="Header 2" family="Liberation Sans" style="BOLD" size="18.0">
        </font>
      </font>
      <vertical_alignment>1</vertical_alignment>
    </widget>
    <widget type="group" version="3.0.0">
      <name>Control</name>
      <x>390</x>
      <y>60</y>
      <width>250</width>
      <height>120</height>
      <widget type="bool_button" version="2.0.0">
        <name>Boolean Button</name>
        <pv_name>${UUT}:INST:$(CH):RUNSTOP</pv_name>
        <x>3</x>
        <y>12</y>
        <height>50</height>
        <off_label>RUN</off_label>
        <on_label>STOP</on_label>
        <actions>
          <action type="write_pv">
            <description>Write PV</description>
            <pv_name>$(pv_name)</pv_name>
            <value>1</value>
          </action>
          <action type="write_pv">
            <description>Write PV</description>
            <pv_name>$(pv_name)</pv_name>
            <value>0</value>
          </action>
        </actions>
      </widget>
      <widget type="textupdate" version="2.0.0">
        <name>Text Update</name>
        <pv_name>${UUT}:INST:${CH}:UPDATES</pv_name>
        <x>3</x>
        <y>72</y>
        <width>111</width>
      </widget>
    </widget>
    <widget type="combo" version="2.0.0">
      <name>Combo Box</name>
      <pv_name>${UUT}:INST:${CH}:MON_RL</pv_name>
      <x>522</x>
      <y>10</y>
      <width>110</width>
    </widget>
    <widget type="group" version="3.0.0">
      <name>Redis Settings</name>
      <x>10</x>
      <y>200</y>
      <width>622</width>
      <widget type="textentry" version="3.0.0">
        <name>Text Entry</name>
        <pv_name>pva://${UUT}:INST:${CH}:REDIS:SET/HOST</pv_name>
        <x>102</x>
        <y>22</y>
        <width>60</width>
      </widget>
      <widget type="textentry" version="3.0.0">
        <name>Text Entry_1</name>
        <pv_name>pva://${UUT}:INST:${CH}:REDIS:SET/PORT</pv_name>
        <x>392</x>
        <y>22</y>
        <width>70</width>
      </widget>
      <widget type="textentry" version="3.0.0">
        <name>Text Entry_3</name>
        <pv_name>pva://${UUT}:INST:${CH}:REDIS:SET/MKEY</pv_name>
        <x>102</x>
        <y>102</y>
        <width>280</width>
      </widget>
      <widget type="label" version="2.0.0">
        <name>Label</name>
        <text>HOST</text>
        <x>2</x>
        <y>22</y>
        <width>40</width>
      </widget>
      <widget type="label" version="2.0.0">
        <name>Label_1</name>
        <text>PORT</text>
        <x>272</x>
        <y>22</y>
      </widget>
      <widget type="label" version="2.0.0">
        <name>Label_2</name>
        <text>MKEY</text>
        <x>2</x>
        <y>102</y>
      </widget>
