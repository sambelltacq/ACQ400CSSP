      <widget type="textentry" version="3.0.0">
        <name>Text Entry_6</name>
        <pv_name>pva://${UUT}:INST:${CH}:REDIS:STA/STATUS</pv_name>
        <x>402</x>
        <y>22</y>
        <width>110</width>
      </widget>
      <widget type="label" version="2.0.0">
        <name>Label_4</name>
        <text>BCOUNT</text>
        <x>2</x>
        <y>22</y>
        <width>70</width>
      </widget>
      <widget type="label" version="2.0.0">
        <name>Label_5</name>
        <text>MMKEY</text>
        <x>2</x>
        <y>62</y>
      </widget>
      <widget type="label" version="2.0.0">
        <name>Label_6</name>
        <text>STATUS</text>
        <x>282</x>
        <y>22</y>
      </widget>
    </widget>
  </widget>
  <widget type="group" version="3.0.0">
    <name>MGT STATUS</name>
    <macros>
      <pvname0>${UUT}:SYS:C:TEMP</pvname0>
      <pvname1>${UUT}:A:FPGA:TEMP</pvname1>
      <pvname2>${UUT}:SYS:MGTD:3V3</pvname2>
      <pvname3>${UUT}:SYS:MGTD:1V8</pvname3>
    </macros>
    <x>490</x>
    <y>520</y>
    <width>140</width>
    <visible>false</visible>
    <style>3</style>
    <transparent>true</transparent>
    <rules>
      <rule name="HIDE_EMPTY" prop_id="visible" out_exp="true">
        <exp bool_exp="pvStr0.find(&quot;_9501_&quot;) &gt;= 0">
          <expression>true</expression>
        </exp>
        <exp bool_exp="pvStr0.find(&quot;_9511_&quot;) &gt;= 0">
          <expression>true</expression>
        </exp>
        <exp bool_exp="true">
          <expression>false</expression>
        </exp>
        <pv_name>${UUT}:SYS:VERSION:FPGA</pv_name>
      </rule>
    </rules>
    <widget type="thermometer" version="2.0.0">
      <name>TEMP_3</name>
      <pv_name>$(pvname0)</pv_name>
      <y>30</y>
      <width>70</width>
      <height>90</height>
      <fill_color>
        <color name="MAJOR" red="255" green="0" blue="0">
        </color>
      </fill_color>
      <border_alarm_sensitive>$(SHOW_ALARM=1)</border_alarm_sensitive>
      <limits_from_pv>false</limits_from_pv>
      <maximum>75.0</maximum>
    </widget>
    <widget type="textupdate" version="2.0.0">
      <name>UPDATE_6</name>
      <pv_name>$(pvname0)</pv_name>
      <x>10</x>
      <y>80</y>
      <width>50</width>
      <height>40</height>
      <font>
        <font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0">
        </font>
      </font>
      <foreground_color>
        <color red="255" green="255" blue="255">
        </color>
      </foreground_color>
      <transparent>true</transparent>
      <format>1</format>
      <horizontal_alignment>1</horizontal_alignment>
      <vertical_alignment>1</vertical_alignment>
    </widget>
    <widget type="thermometer" version="2.0.0">
      <name>TEMP_4</name>
