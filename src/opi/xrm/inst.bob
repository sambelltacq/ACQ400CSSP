      <name>Redis Status</name>
      <x>20</x>
      <y>420</y>
      <width>612</width>
      <height>120</height>
      <widget type="textentry" version="3.0.0">
        <name>Text Entry_2</name>
        <pv_name>pva://${UUT}:INST:${CH}:REDIS:STA/BCOUNT</pv_name>
        <x>112</x>
        <y>22</y>
      </widget>
      <widget type="textentry" version="3.0.0">
        <name>Text Entry_5</name>
        <pv_name>pva://${UUT}:INST:${CH}:REDIS:STA/MMKEY</pv_name>
