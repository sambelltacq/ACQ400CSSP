<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>XRM Launcher</name>
  <width>820</width>
  <height>970</height>
  <widget type="group" version="3.0.0">
    <name>INIT LOC</name>
    <x>690</x>
    <width>130</width>
    <height>81</height>
    <visible>$(DEBUG)</visible>
    <style>3</style>
    <transparent>true</transparent>
    <widget type="label" version="2.0.0">
      <name>GLOBAL_MACROS</name>
      <text>GLOBAL MACROS</text>
      <width>122</width>
      <height>16</height>
      <auto_size>true</auto_size>
      <scripts>
        <script file="scripts/handle_macro.py">
          <pv_name>loc://SLICEHOST_$(DID)</pv_name>
        </script>
      </scripts>
    </widget>
    <widget type="textupdate" version="2.0.0">
      <name>INIT LOC://UUT</name>
      <pv_name>loc://SLICEHOST_$(DID)&lt;VString&gt;("acq1102_056")</pv_name>
      <y>30</y>
      <width>130</width>
      <background_color>
        <color red="255" green="212" blue="0">
        </color>
      </background_color>
      <precision>0</precision>
      <vertical_alignment>1</vertical_alignment>
    </widget>
  </widget>
  <widget type="label" version="2.0.0">
    <name>OPI TITLE</name>
    <text>XRM Launcher</text>
    <x>20</x>
    <y>16</y>
    <width>170</width>
    <height>30</height>
    <font>
      <font name="Header 1" family="Liberation Sans" style="BOLD" size="22.0">
      </font>
    </font>
    <vertical_alignment>2</vertical_alignment>
  </widget>
  <widget type="label" version="2.0.0">
    <name>UUTNAME</name>
    <text>$(UUT)</text>
    <x>20</x>
    <y>40</y>
    <width>130</width>
    <font>
      <font name="Header 3" family="Liberation Sans" style="BOLD" size="16.0">
      </font>
    </font>
    <vertical_alignment>2</vertical_alignment>
  </widget>
  <widget type="group" version="3.0.0">
    <name>XRM GROUP</name>
    <x>20</x>
    <y>120</y>
    <width>150</width>
    <height>150</height>
    <style>3</style>
    <transparent>true</transparent>
    <widget type="action_button" version="3.0.0">
      <name>soe ht Button</name>
      <actions>
        <action type="execute">
          <description>open opi/xrm/soe_ht.bob</description>
          <script file="scripts/handle_action_button.py">
          </script>
        </action>
      </actions>
      <text>SOE HT</text>
      <y>80</y>
      <width>150</width>
      <font>
        <font family="Ubuntu" style="BOLD" size="14.0">
        </font>
      </font>
      <tooltip>SOE Hold Table</tooltip>
    </widget>
    <widget type="action_button" version="3.0.0">
      <name>fmt rx Button_3</name>
      <actions>
        <action type="execute">
          <description>open opi/xrm/fmt_rx.bob</description>
          <script file="scripts/handle_action_button.py">
          </script>
        </action>
      </actions>
      <text>FMT RX</text>
      <width>150</width>
      <font>
        <font family="Ubuntu" style="BOLD" size="14.0">
        </font>
      </font>
      <tooltip>FMT RX</tooltip>
    </widget>
    <widget type="action_button" version="3.0.0">
      <name>soe lut Button_2</name>
      <actions>
        <action type="execute">
          <description>open opi/xrm/soe_lut.bob</description>
          <script file="scripts/handle_action_button.py">
          </script>
        </action>
      </actions>
      <text>SOE LUT</text>
      <y>40</y>
      <width>150</width>
      <font>
        <font family="Ubuntu" style="BOLD" size="14.0">
        </font>
      </font>
      <tooltip>SOE Lookup Table</tooltip>
    </widget>
    <widget type="action_button" version="3.0.0">
      <name>pm Button</name>
      <actions>
        <action type="execute">
          <description>open opi/xrm/pm.bob</description>
          <script file="scripts/handle_action_button.py">
          </script>
        </action>
      </actions>
      <text>PM</text>
      <y>120</y>
      <width>150</width>
      <font>
        <font family="Ubuntu" style="BOLD" size="14.0">
        </font>
      </font>
      <tooltip>Post Mortem</tooltip>
    </widget>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>fmt sim Button</name>
    <actions>
      <action type="execute">
        <description>open opi/xrm/fmt_sim.bob</description>
        <script file="scripts/handle_action_button.py">
        </script>
      </action>
    </actions>
    <text>FMT SIM</text>
    <x>340</x>
    <y>120</y>
    <width>150</width>
    <font>
      <font family="Ubuntu" style="BOLD" size="14.0">
      </font>
    </font>
    <tooltip>FMT SIM</tooltip>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label</name>
    <text>XRM Device
(Controls)</text>
    <x>20</x>
    <y>80</y>
    <width>150</width>
    <height>40</height>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_1</name>
    <text>Simulation</text>
    <x>340</x>
    <y>100</y>
    <width>90</width>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_2</name>
    <text>SOE FMT RX SUCCESS</text>
    <x>20</x>
    <y>290</y>
    <width>180</width>
    <height>30</height>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>Text Update</name>
    <pv_name>${UUT}:SOE:FMT_RX_SUCCESS</pv_name>
    <x>200</x>
    <y>290</y>
    <width>150</width>
    <height>30</height>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_3</name>
    <text>SOE FMT RX TIMEOUTS</text>
    <x>370</x>
    <y>290</y>
    <width>180</width>
    <height>30</height>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>Text Update_1</name>
