    <x>20</x>
    <y>120</y>
    <width>150</width>
    <height>150</height>
    <style>3</style>
    <transparent>true</transparent>
    <widget type="action_button" version="3.0.0">
      <name>soe ht Button</name>
      <actions>
        <action type="execute">
          <description>open opi/xrm/soe_ht.bob</description>
          <script file="scripts/handle_action_button.py">
          </script>
        </action>
      </actions>
      <text>SOE HT</text>
      <y>80</y>
      <width>150</width>
      <font>
        <font family="Ubuntu" style="BOLD" size="14.0">
        </font>
      </font>
