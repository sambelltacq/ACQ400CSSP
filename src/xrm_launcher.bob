    <x>580</x>
    <y>290</y>
    <width>160</width>
    <height>30</height>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_4</name>
    <text>SOE FMT TIMEOUT REASON</text>
    <x>370</x>
    <y>320</y>
    <width>200</width>
    <height>30</height>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>Text Update_2</name>
