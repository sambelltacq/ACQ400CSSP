    <height>30</height>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_5</name>
    <text>SOE FMT RX DELTA TS</text>
    <x>20</x>
    <y>320</y>
    <width>180</width>
    <height>30</height>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>Text Update_3</name>
    <pv_name>${UUT}:SOE:FMT:DELTA_TS</pv_name>
    <x>200</x>
    <y>320</y>
    <width>150</width>
    <height>30</height>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_6</name>
    <text>SOE FMT EV MATCHES</text>
    <x>20</x>
    <y>350</y>
    <width>180</width>
    <height>30</height>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>Text Update_4</name>
    <pv_name>${UUT}:SOE:FMT:EV_MATCHES</pv_name>
    <x>200</x>
    <y>350</y>
    <width>150</width>
    <height>30</height>
  </widget>
  <widget type="combo" version="2.0.0">
    <name>Combo Box</name>
    <pv_name>${UUT}:SOE:STRATEGY</pv_name>
    <x>190</x>
    <y>120</y>
    <width>130</width>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_7</name>
    <text>SOE FMT EV NIB</text>
    <x>20</x>
    <y>380</y>
    <width>180</width>
    <height>30</height>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>Text Update_5</name>
    <pv_name>${UUT}:SOE:FMT:EV_NIB</pv_name>
    <x>200</x>
    <y>380</y>
    <width>150</width>
    <height>30</height>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_8</name>
    <text>XRM Device
(Instrumentation)</text>
    <x>510</x>
    <y>80</y>
    <width>150</width>
    <height>40</height>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>stream_initButton1</name>
    <actions>
      <action type="open_display">
        <description>INST 1</description>
        <file>opi/xrm/inst.bob</file>
        <macros>
          <CH>1</CH>
        </macros>
        <target>tab</target>
      </action>
    </actions>
    <text>INST1</text>
    <x>510</x>
    <y>120</y>
    <width>150</width>
    <font>
      <font family="Ubuntu" style="BOLD" size="14.0">
      </font>
    </font>
    <tooltip>INST 1 data stream</tooltip>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>stream_initButton2</name>
    <actions>
      <action type="open_display">
        <description>INST2</description>
        <file>opi/xrm/inst.bob</file>
        <macros>
          <CH>2</CH>
        </macros>
        <target>tab</target>
      </action>
    </actions>
    <text>INST2</text>
    <x>510</x>
    <y>160</y>
    <width>150</width>
    <font>
      <font family="Ubuntu" style="BOLD" size="14.0">
      </font>
    </font>
    <tooltip>INST 2 data stream</tooltip>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>Text Update_6</name>
    <pv_name>${UUT}:0:MODEL</pv_name>
    <x>350</x>
    <y>20</y>
    <width>140</width>
  </widget>
  <widget type="textentry" version="3.0.0">
    <name>Text Entry</name>
    <pv_name>loc://SLICEHOST_$(DID)</pv_name>
    <x>20</x>
    <y>480</y>
    <width>130</width>
    <height>30</height>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_10</name>
    <class>SECTION</class>
    <text>SliceHost</text>
    <x>20</x>
    <y>460</y>
    <width>130</width>
    <font use_class="true">
      <font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0">
      </font>
    </font>
    <foreground_color use_class="true">
      <color name="Text" red="0" green="0" blue="0">
      </color>
    </foreground_color>
    <transparent use_class="true">true</transparent>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>soe slice Button</name>
    <actions>
      <action type="execute">
        <description>open opi/xrm/soe_slice.bob</description>
        <script file="scripts/handle_action_button.py">
        </script>
      </action>
    </actions>
    <text>SOE SLICE</text>
    <x>160</x>
    <y>480</y>
    <width>150</width>
    <font>
      <font family="Ubuntu" style="BOLD" size="14.0">
      </font>
    </font>
    <tooltip>Analog Trigger Thresholds</tooltip>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>pm slice Button</name>
    <actions>
      <action type="execute">
        <description>open opi/xrm/pm_slice.bob</description>
        <script file="scripts/handle_action_button.py">
        </script>
      </action>
    </actions>
    <text>PM SLICE</text>
    <x>320</x>
    <y>480</y>
    <width>150</width>
    <font>
      <font family="Ubuntu" style="BOLD" size="14.0">
      </font>
    </font>
    <tooltip>Analog Trigger Thresholds</tooltip>
  </widget>
</display>
