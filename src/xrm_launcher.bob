<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>XRM Launcher</name>
  <width>820</width>
  <height>970</height>
  <widget type="label" version="2.0.0">
    <name>OPI TITLE</name>
    <text>XRM Launcher</text>
    <x>10</x>
    <y>10</y>
    <width>170</width>
    <height>30</height>
    <font>
      <font name="Header 1" family="Liberation Sans" style="BOLD" size="22.0">
      </font>
    </font>
